# Used only when running the backend directly with `npm run dev`
# (outside Docker). Inside docker-compose, these are set as
# environment variables in docker-compose.yml instead.

PORT=4000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=employee_management

# Origin of the frontend during local dev, for CORS
CORS_ORIGIN=http://localhost:5173
